{
  "name": "@waywake/ovopark-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Ovopark open platform gateway.",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "homepage": "https://github.com/waywake/ovopark-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/waywake/ovopark-sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/waywake/ovopark-sdk-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ovopark",
    "open-platform",
    "sdk",
    "typescript"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "build:cjs": "bun build ./src/index.ts --target node --format cjs --packages external --outfile ./dist/index.cjs",
    "build:esm": "bun build ./src/index.ts --target node --format esm --packages external --outfile ./dist/index.js",
    "build:types": "tsc -p tsconfig.build.json",
    "check": "bun test && bun run typecheck && bun run build",
    "clean": "rm -rf dist",
    "example": "bun examples/get-departments.ts",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
